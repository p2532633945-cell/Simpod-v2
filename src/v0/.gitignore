# 依赖库（这个文件夹很大，绝对不能上传，运行 npm install 时会自动生成）
node_modules/

# 环境变量（最关键！里面有你的 Groq 和 Supabase Key，绝不能公开）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js 编译产物（这是程序运行生成的临时文件）
.next/
out/
build/

# 系统冗余文件
.DS_Store
Thumbs.db

# 日志文件
*.log
npm-debug.log*

# Example projects
example-*/