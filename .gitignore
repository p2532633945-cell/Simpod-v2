# 依赖库（这个文件夹很大，绝对不能上传，运行 npm install 时会自动生成）
node_modules/
.pnp/
.pnp.js

# 环境变量（最关键！里面有你的 Groq 和 Supabase Key，绝不能公开）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js 编译产物（这是程序运行生成的临时文件）
.next/
out/
build/
next-env.d.ts

# 测试覆盖率
coverage/
.nyc_output/

# 系统冗余文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Example projects
example-*/

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Verbose build
*.tsbuildinfo

# Temporary files
tmp/
temp/
.vercel
